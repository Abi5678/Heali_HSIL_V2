# MedLive Environment Variables
# Copy this to .env and fill in your values

# Set to 1/true/yes to skip login for local testing (no redirect to auth; use demo_user)
# SKIP_AUTH_FOR_TESTING=

# Secret for local JWT authentication (required if USE_LOCAL_AUTH=true)
# JWT_SECRET=change-me-to-a-secure-random-string

# Gemini API Key (fallback if Vertex AI is disabled)
GOOGLE_API_KEY=your-gemini-api-key-here

# GCP Project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Firebase Admin SDK credentials path
GOOGLE_APPLICATION_CREDENTIALS=credentials/firebase-admin-sdk.json

# Use Vertex AI (routes Gemini through GCP billing)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Agent Model (native audio for voice streaming)
MEDLIVE_MODEL=gemini-2.5-flash-native-audio-latest

# Firestore toggle (set to false to use in-memory mock data)
USE_FIRESTORE=true

# Proactive push reminders (meds + lunch)
REMINDERS_TRIGGER_SECRET=your-internal-secret-for-cloud-scheduler
MEDLIVE_APP_URL=https://your-app-domain.com
# Web Push VAPID key (Firebase Console > Project Settings > Cloud Messaging > Web configuration)
VAPID_KEY=

# Twilio Voice Call Reminders (outbound calls to patients)
# Sign up free at twilio.com — trial gives ~$15 credit (~1000 reminder calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=       # Your Twilio number, e.g. +15005550006
TWILIO_DEMO_PHONE=         # Your real phone number for demo/testing calls

# Wearable & CGM Integration (direct OAuth per provider)
# Dexcom CGM (https://developer.dexcom.com/)
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_BASE_URL=https://sandbox-api.dexcom.com

# Fitbit (https://dev.fitbit.com/)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Garmin Health API (https://developer.garmin.com/)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Strava (https://developers.strava.com/)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# OAuth callback base URL (your public app domain)
OAUTH_CALLBACK_BASE_URL=https://your-app-domain.com/api/wearables/callback

# Fernet encryption key for storing OAuth tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
WEARABLE_TOKEN_ENCRYPTION_KEY=
